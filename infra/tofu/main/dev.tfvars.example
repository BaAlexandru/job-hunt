# Copy to dev.tfvars and fill in your values
# Usage: tofu plan -var-file=dev.tfvars

allowed_ssh_cidr    = "YOUR_IP/32"       # e.g., "203.0.113.42/32"
alert_email         = "you@example.com"  # SNS billing alert email
ssh_public_key_path = "~/.ssh/jobhunt-deployer.pub"
# instance_type     = "t3.small"         # default, uncomment to override
# region            = "eu-central-1"     # default, uncomment to override
